<!DOCTYPE html>
<html>
<head>
  <title>MyBank - Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Poppins', sans-serif;
    }

    body {
      background: #f4f7fa;
    }

    .navbar {
      background: #0d6efd;
      color: white;
      padding: 15px 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .navbar h2 {
      font-weight: 600;
    }

    .navbar .user {
      font-size: 14px;
    }

    .container {
      padding: 30px;
      max-width: 1200px;
      margin: auto;
    }

    .balance-card {
      background: linear-gradient(135deg, #0d6efd, #4e9bff);
      color: white;
      padding: 25px;
      border-radius: 15px;
      margin-bottom: 30px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    .balance-card h3 {
      font-weight: 400;
    }

    .balance-amount {
      font-size: 32px;
      margin-top: 10px;
      font-weight: 600;
    }

    .services {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin-bottom: 40px;
    }

    .service-card {
      background: white;
      padding: 20px;
      border-radius: 12px;
      text-align: center;
      cursor: pointer;
      transition: 0.3s;
      box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    .service-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    .service-card h4 {
      margin-top: 10px;
      font-weight: 500;
    }

    .transactions {
      background: white;
      padding: 20px;
      border-radius: 12px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 15px;
    }

    th, td {
      padding: 10px;
      text-align: left;
      border-bottom: 1px solid #eee;
      font-size: 14px;
    }

    th {
      background: #f0f2f5;
    }

    .credit {
      color: green;
      font-weight: 600;
    }

    .debit {
      color: red;
      font-weight: 600;
    }
  </style>
</head>

<body>

<div class="navbar">
  <h2>MyBank</h2>
  <div class="user">Welcome, <%= user.username %></div>
</div>

<div class="container">

  <!-- Balance Section -->
  <div class="balance-card">
    <h3>Available Balance</h3>
    <div class="balance-amount" id="balance">₹0</div>
  </div>

  <!-- Banking Services -->
  <div class="services">
    <div class="service-card" onclick="deposit()">
      💰
      <h4>Deposit</h4>
    </div>

    <div class="service-card" onclick="withdraw()">
      💳
      <h4>Withdraw</h4>
    </div>

    <div class="service-card" onclick="transfer()">
      🔄
      <h4>Transfer</h4>
    </div>

    <div class="service-card" onclick="payBills()">
      🧾
      <h4>Pay Bills</h4>
    </div>

    <div class="service-card" onclick="applyLoan()">
      🏦
      <h4>Apply Loan</h4>
    </div>
  </div>

  <!-- Transactions -->
  <div class="transactions">
    <h3>Recent Transactions</h3>
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Service</th>
          <th>Amount</th>
          <th>Recipient</th>
        </tr>
      </thead>
      <tbody id="transactionTable">
      </tbody>
    </table>
  </div>

</div>

<script>
const userId = <%= user.id %>;

async function fetchTransactions() {
  const res = await fetch(`/services/${userId}`);
  const data = await res.json();

  const table = document.getElementById("transactionTable");
  table.innerHTML = "";

  let balance = 0;

  data.forEach(t => {
    if (t.service_type === 'Deposit') balance += parseFloat(t.amount);
    if (['Withdraw','Bill Payment','Transfer'].includes(t.service_type))
      balance -= parseFloat(t.amount);
  });

  document.getElementById("balance").textContent = `₹${balance}`;

  data.slice(-5).reverse().forEach(t => {
    const row = `
      <tr>
        <td>${new Date(t.created_at).toLocaleString()}</td>
        <td>${t.service_type}</td>
        <td class="${t.service_type === 'Deposit' ? 'credit' : 'debit'}">
          ₹${t.amount}
        </td>
        <td>${t.recipient || '-'}</td>
      </tr>
    `;
    table.innerHTML += row;
  });
}

async function callService(type, amount=0, recipient='') {
  await fetch('/service', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ userId, serviceType:type, amount, recipient })
  });
  fetchTransactions();
}

function deposit() {
  const amt = parseFloat(prompt("Enter deposit amount ₹:"));
  if (amt > 0) callService('Deposit', amt);
}

function withdraw() {
  const amt = parseFloat(prompt("Enter withdraw amount ₹:"));
  if (amt > 0) callService('Withdraw', amt);
}

function transfer() {
  const recipient = prompt("Enter recipient username:");
  const amt = parseFloat(prompt("Enter transfer amount ₹:"));
  if (recipient && amt > 0) callService('Transfer', amt, recipient);
}

function payBills() {
  const bill = prompt("Bill type:");
  const amt = parseFloat(prompt("Enter bill amount ₹:"));
  if (bill && amt > 0) callService('Bill Payment', amt, bill);
}

function applyLoan() {
  const amt = parseFloat(prompt("Loan amount ₹:"));
  if (amt > 0) callService('Loan Applied', amt);
}

fetchTransactions();
</script>

</body>
</html>
