<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Secure Banking Dashboard</title>

<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Roboto',sans-serif;
}

body{
  background:#f4f6f9;
}

/* Header */
header{
  background:#0b3c5d;
  padding:18px 40px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  color:white;
}

header h2{
  font-weight:500;
  letter-spacing:0.5px;
}

.logout-btn{
  background:#d4af37;
  border:none;
  padding:8px 20px;
  border-radius:4px;
  font-weight:500;
  cursor:pointer;
  transition:0.3s;
}

.logout-btn:hover{
  background:#b8962e;
}

/* Container */
.container{
  padding:40px;
}

/* Balance Card */
.balance-card{
  background:white;
  padding:30px;
  border-radius:8px;
  box-shadow:0 4px 15px rgba(0,0,0,0.08);
  margin-bottom:35px;
  border-left:6px solid #0b3c5d;
}

.balance-card h3{
  color:#555;
  font-weight:400;
}

.balance-card h1{
  margin-top:10px;
  color:#0b3c5d;
  font-size:36px;
}

/* Services */
.services{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
  gap:20px;
  margin-bottom:35px;
}

.card{
  background:white;
  padding:25px;
  border-radius:8px;
  text-align:center;
  cursor:pointer;
  transition:0.3s;
  box-shadow:0 3px 12px rgba(0,0,0,0.08);
  border-top:4px solid #0b3c5d;
}

.card:hover{
  transform:translateY(-5px);
  box-shadow:0 6px 20px rgba(0,0,0,0.12);
}

.card h3{
  margin-bottom:8px;
  color:#0b3c5d;
  font-weight:500;
}

.card p{
  font-size:14px;
  color:#666;
}

/* Transactions */
.transactions{
  background:white;
  padding:30px;
  border-radius:8px;
  box-shadow:0 4px 15px rgba(0,0,0,0.08);
}

.transactions h3{
  margin-bottom:15px;
  color:#0b3c5d;
  font-weight:500;
}

.transaction-item{
  padding:12px 0;
  border-bottom:1px solid #eee;
  font-size:14px;
  color:#444;
}

.transaction-item:last-child{
  border-bottom:none;
}

/* Responsive */
@media(max-width:768px){
  .container{
    padding:20px;
  }
}
</style>
</head>

<body>

<header>
  <h2>Welcome, <%= user.username %></h2>
  <form action="/logout" method="GET">
    <button class="logout-btn">Logout</button>
  </form>
</header>

<div class="container">

  <div class="balance-card">
    <h3>Available Balance</h3>
    <h1 id="balanceAmount">₹ 0</h1>
  </div>

  <div class="services">

    <div class="card" onclick="depositMoney()">
      <h3>Deposit Funds</h3>
      <p>Add money to your savings account</p>
    </div>

    <div class="card" onclick="withdrawMoney()">
      <h3>Withdraw Funds</h3>
      <p>Secure cash withdrawal</p>
    </div>

    <div class="card" onclick="transferFunds()">
      <h3>Fund Transfer</h3>
      <p>Transfer money instantly</p>
    </div>

    <div class="card" onclick="payBills()">
      <h3>Bill Payments</h3>
      <p>Electricity, Water, Mobile</p>
    </div>

    <div class="card" onclick="applyLoan()">
      <h3>Loan Services</h3>
      <p>Apply for personal loan</p>
    </div>

    <div class="card" onclick="loadTransactions()">
      <h3>Transaction History</h3>
      <p>View recent account activity</p>
    </div>

  </div>

  <div class="transactions">
    <h3>Recent Transactions</h3>
    <div id="transaction-history"></div>
  </div>

</div>

<script>
const userId = <%= user.id %>;

async function callService(type, amount = 0, recipient = '') {
  const res = await fetch('/service', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({ userId, serviceType: type, amount, recipient })
  });
  return await res.json();
}

async function loadTransactions() {
  const res = await fetch(`/services/${userId}`);
  const data = await res.json();
  const container = document.getElementById('transaction-history');
  container.innerHTML = '';

  let balance = 0;

  data.forEach(t => {
    if (t.service_type === 'Deposit') balance += parseFloat(t.amount);
    if (['Withdraw','Bill Payment','Transfer','Loan Applied'].includes(t.service_type))
      balance -= parseFloat(t.amount);

    const div = document.createElement('div');
    div.classList.add('transaction-item');
    div.textContent = `${t.created_at} | ${t.service_type} | ₹${t.amount} ${t.recipient || ''}`;
    container.appendChild(div);
  });

  document.getElementById('balanceAmount').textContent = `₹ ${balance}`;
}

async function depositMoney() {
  const amount = parseFloat(prompt('Enter deposit amount (₹):'));
  if(amount > 0){ await callService('Deposit', amount); loadTransactions(); }
}

async function withdrawMoney() {
  const amount = parseFloat(prompt('Enter withdraw amount (₹):'));
  if(amount > 0){ await callService('Withdraw', amount); loadTransactions(); }
}

async function transferFunds() {
  const recipient = prompt('Recipient username:');
  const amount = parseFloat(prompt('Transfer amount (₹):'));
  if(recipient && amount > 0){ await callService('Transfer', amount, recipient); loadTransactions(); }
}

async function payBills() {
  const billType = prompt('Bill type:');
  const amount = parseFloat(prompt('Bill amount (₹):'));
  if(billType && amount > 0){ await callService('Bill Payment', amount, billType); loadTransactions(); }
}

async function applyLoan() {
  const amount = parseFloat(prompt('Loan amount (₹):'));
  if(amount > 0){ await callService('Loan Applied', amount); loadTransactions(); }
}

window.onload = loadTransactions;
</script>

</body>
</html>
