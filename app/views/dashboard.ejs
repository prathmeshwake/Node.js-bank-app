<!DOCTYPE html>
<html>
<head>
  <title>Bank Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f4f6f9;
      margin: 0;
      padding: 20px;
    }

    h2 {
      text-align: center;
    }

    .dashboard {
      max-width: 900px;
      margin: auto;
    }

    .card {
      background: #fff;
      padding: 20px;
      margin-bottom: 20px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    button {
      padding: 10px 15px;
      margin: 5px;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      background: #007bff;
      color: #fff;
    }

    button:hover {
      background: #0056b3;
    }

    .result {
      margin-top: 10px;
      font-weight: bold;
      color: green;
    }
  </style>
</head>

<body>

<div class="dashboard">

  <h2>Welcome, <%= user.username %> 👋</h2>

  <!-- CHECK BALANCE -->
  <div class="card" id="check-balance">
    <button>Check Balance</button>
    <div class="result"></div>
  </div>

  <!-- DEPOSIT -->
  <div class="card" id="deposit-money">
    <button>Deposit Money</button>
  </div>

  <!-- WITHDRAW -->
  <div class="card" id="withdraw-money">
    <button>Withdraw Money</button>
  </div>

  <!-- TRANSFER -->
  <div class="card" id="transfer-funds">
    <button>Transfer Funds</button>
  </div>

  <!-- PAY BILLS -->
  <div class="card" id="pay-bills">
    <button>Pay Bills</button>
  </div>

  <!-- APPLY LOAN -->
  <div class="card" id="apply-loan">
    <button>Apply for Loan</button>
  </div>

  <!-- TRANSACTION HISTORY -->
  <div class="card" id="transaction-history">
    <button>View Last 5 Transactions</button>
    <div class="result"></div>
  </div>

</div>

<script>
const userId = <%= user.id %>;

async function callService(type, amount = 0, recipient = '') {
  const res = await fetch('/service', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({ userId, serviceType: type, amount, recipient })
  });
  return await res.json();
}

async function loadTransactions() {
  const res = await fetch(`/services/${userId}`);
  const data = await res.json();
  const container = document.getElementById('transaction-history').querySelector('.result');
  if (!data.length) container.textContent = 'No transactions yet.';
  else container.innerHTML = data
      .slice(-5)
      .map(t => `${new Date(t.created_at).toLocaleString()} - ${t.service_type} - ₹${t.amount || 0} ${t.recipient || ''}`)
      .join('<br>');
}

document.querySelector('#check-balance button').addEventListener('click', async function() {
  const res = await fetch(`/services/${userId}`);
  const data = await res.json();
  let balance = 0;
  data.forEach(t => {
    if (t.service_type === 'Deposit') balance += parseFloat(t.amount);
    if (['Withdraw','Bill Payment','Transfer'].includes(t.service_type)) balance -= parseFloat(t.amount);
  });
  document.querySelector('#check-balance .result').textContent = `Balance: ₹${balance}`;
});

document.querySelector('#deposit-money button').addEventListener('click', async function() {
  const amount = parseFloat(prompt('Enter amount to deposit (₹):'));
  if (amount > 0) { await callService('Deposit', amount); loadTransactions(); }
});

document.querySelector('#withdraw-money button').addEventListener('click', async function() {
  const amount = parseFloat(prompt('Enter amount to withdraw (₹):'));
  if (amount > 0) { await callService('Withdraw', amount); loadTransactions(); }
});

document.querySelector('#transfer-funds button').addEventListener('click', async function() {
  const recipient = prompt('Recipient username:');
  const amount = parseFloat(prompt('Amount to transfer (₹):'));
  if (recipient && amount > 0) { await callService('Transfer', amount, recipient); loadTransactions(); }
});

document.querySelector('#pay-bills button').addEventListener('click', async function() {
  const billType = prompt('Bill type:');
  const amount = parseFloat(prompt(`Enter ${billType} amount (₹):`));
  if (billType && amount > 0) { await callService('Bill Payment', amount, billType); loadTransactions(); }
});

document.querySelector('#apply-loan button').addEventListener('click', async function() {
  const amount = parseFloat(prompt('Loan amount (₹):'));
  if (amount > 0) { await callService('Loan Applied', amount); loadTransactions(); }
});

document.querySelector('#transaction-history button').addEventListener('click', loadTransactions);
</script>

</body>
</html>
